    "span": "contract HTLC(\n    byte[32] initHashLock,\n    int initTimeLock,\n    byte[32] initRecipientKeyHash,\n    byte[32] initSenderKeyHash\n) {\n    byte[32] hashLock = initHashLock;\n    int timeLock = initTimeLock;\n    byte[32] recipientKeyHash = initRecipientKeyHash;\n    byte[32] senderKeyHash = initSenderKeyHash;\n\n    int constant MINER_FEE = 1000;\n\n    // Path A: Claim by revealing the SHA-256 preimage\n    entrypoint function claimWithPreimage(\n        byte[32] preimage,\n        pubkey recipientPk,\n        sig recipientSig\n    ) {\n        // Verify preimage matches hashlock\n        require(sha256(preimage) == hashLock);\n\n        // Verify recipient identity\n        require(blake2b(recipientPk) == recipientKeyHash);\n        require(checkSig(recipientSig, recipientPk));\n\n        // Transfer full value to recipient\n        int inputValue = tx.inputs[this.activeInputIndex].value;\n        require(tx.outputs[0].value >= inputValue - MINER_FEE);\n    }\n\n    // Path B: Refund to sender after timelock expires\n    entrypoint function refundAfterTimeout(\n        pubkey senderPk,\n        sig senderSig\n    ) {\n        // Verify sender identity\n        require(blake2b(senderPk) == senderKeyHash);\n        require(checkSig(senderSig, senderPk));\n\n        // Transfer full value back to sender\n        int inputValue = tx.inputs[this.activeInputIndex].value;\n        require(tx.outputs[0].value >= inputValue - MINER_FEE);\n    }\n}",
    "name_span": "HTLC"
