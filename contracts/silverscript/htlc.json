        "span": "entrypoint function claimWithPreimage(\n        byte[32] preimage,\n        pubkey recipientPk,\n        sig recipientSig\n    ) {\n        // Verify preimage matches hashlock\n        require(sha256(preimage) == hashLock);\n\n        // Verify recipient identity\n        require(blake2b(recipientPk) == recipientKeyHash);\n        require(checkSig(recipientSig, recipientPk));\n\n        // Transfer full value to recipient\n        int inputValue = tx.inputs[this.activeInputIndex].value;\n        require(tx.outputs[0].value >= inputValue - MINER_FEE);\n    }",
