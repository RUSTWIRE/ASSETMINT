    "span": "contract Dividend(\n    byte[32] initHolderMerkleRoot,\n    byte[32] initIssuerKeyHash,\n    int initTotalShares,\n    int initDeadline\n) {\n    byte[32] holderMerkleRoot = initHolderMerkleRoot;\n    byte[32] issuerKeyHash = initIssuerKeyHash;\n    int totalShares = initTotalShares;\n    int deadline = initDeadline;\n\n    int constant MINER_FEE = 1000;\n\n    // Path A: Holder claims their proportional dividend\n    entrypoint function claimDividend(\n        pubkey holderPk,\n        sig holderSig,\n        int holderShares,\n        byte[32] merkleProof0,\n        byte[32] merkleProof1\n    ) {\n        // Verify holder signature\n        require(checkSig(holderSig, holderPk));\n        require(holderShares > 0);\n        require(totalShares > 0);\n\n        // Verify holder is in the Merkle tree (simplified 2-level proof)\n        byte[32] leaf = sha256(holderPk);\n        byte[32] intermediate = sha256(leaf + merkleProof0);\n        byte[32] computedRoot = sha256(intermediate + merkleProof1);\n        require(computedRoot == holderMerkleRoot);\n\n        // Calculate proportional claim\n        int inputValue = tx.inputs[this.activeInputIndex].value;\n        int claimAmount = (inputValue * holderShares) / totalShares;\n        require(claimAmount > MINER_FEE);\n\n        // Output 0: holder receives claim\n        require(tx.outputs[0].value >= claimAmount - MINER_FEE);\n\n        // Covenant preservation: remaining goes back to contract\n        int remaining = inputValue - claimAmount;\n        if (remaining > MINER_FEE) {\n            require(tx.outputs[1].value >= remaining - MINER_FEE);\n            validateOutputState(1, {\n                holderMerkleRoot: holderMerkleRoot,\n                issuerKeyHash: issuerKeyHash,\n                totalShares: totalShares,\n                deadline: deadline\n            });\n        }\n    }\n\n    // Path B: Issuer adds more funds for distribution\n    entrypoint function issuerTopUp(pubkey issuerPk, sig issuerSig) {\n        require(blake2b(issuerPk) == issuerKeyHash);\n        require(checkSig(issuerSig, issuerPk));\n\n        // Preserve covenant with all existing state\n        int inputValue = tx.inputs[this.activeInputIndex].value;\n        require(tx.outputs[0].value >= inputValue);\n        validateOutputState(0, {\n            holderMerkleRoot: holderMerkleRoot,\n            issuerKeyHash: issuerKeyHash,\n            totalShares: totalShares,\n            deadline: deadline\n        });\n    }\n\n    // Path C: Issuer reclaims unclaimed funds\n    entrypoint function issuerReclaim(pubkey issuerPk, sig issuerSig) {\n        require(blake2b(issuerPk) == issuerKeyHash);\n        require(checkSig(issuerSig, issuerPk));\n    }\n}",
