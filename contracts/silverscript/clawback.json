        "span": "entrypoint function issuerClawback(\n        pubkey issuerPk,\n        sig issuerSig,\n        pubkey issuerReceivePk\n    ) {\n        // Verify issuer identity via hash commitment\n        require(blake2b(issuerPk) == issuerKeyHash);\n        require(checkSig(issuerSig, issuerPk));\n\n        // First output: send reclaimed funds to issuer's receive address\n        byte[34] issuerLock = new ScriptPubKeyP2PK(issuerReceivePk);\n        require(tx.outputs[0].scriptPubKey == issuerLock);\n\n        // Transfer full value minus fee\n        int inputValue = tx.inputs[this.activeInputIndex].value;\n        require(tx.outputs[0].value >= inputValue - MINER_FEE);\n\n        // Second output: OP_RETURN with clawback reason metadata\n        // The reason is encoded in the transaction witness data\n        // Enforce that a second output exists (for the OP_RETURN data)\n        require(tx.outputs.length >= 2);\n    }",
        "name_span": "issuerClawback",
        "body_span": "require(blake2b(issuerPk) == issuerKeyHash);\n        require(checkSig(issuerSig, issuerPk));\n\n        // First output: send reclaimed funds to issuer's receive address\n        byte[34] issuerLock = new ScriptPubKeyP2PK(issuerReceivePk);\n        require(tx.outputs[0].scriptPubKey == issuerLock);\n\n        // Transfer full value minus fee\n        int inputValue = tx.inputs[this.activeInputIndex].value;\n        require(tx.outputs[0].value >= inputValue - MINER_FEE);\n\n        // Second output: OP_RETURN with clawback reason metadata\n        // The reason is encoded in the transaction witness data\n        // Enforce that a second output exists (for the OP_RETURN data)\n        require(tx.outputs.length >= 2);"
      }
