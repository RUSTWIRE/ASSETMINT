    "span": "contract Clawback(\n    pubkey owner,\n    byte[32] issuerKeyHash\n) {\n    int constant MINER_FEE = 1000;\n\n    // Path A: Owner spends normally\n    // The owner can transfer the UTXO to any recipient\n    entrypoint function ownerSpend(sig ownerSig, pubkey recipientPk) {\n        // Verify the owner's signature\n        require(checkSig(ownerSig, owner));\n\n        // First output must go to the specified recipient\n        byte[34] recipientLock = new ScriptPubKeyP2PK(recipientPk);\n        require(tx.outputs[0].scriptPubKey == recipientLock);\n\n        // Ensure meaningful transfer amount\n        int inputValue = tx.inputs[this.activeInputIndex].value;\n        require(tx.outputs[0].value >= inputValue - MINER_FEE);\n    }\n\n    // Path B: Issuer clawback — unconditional reclaim\n    // The issuer can reclaim the UTXO at any time for regulatory reasons.\n    // A second output carries OP_RETURN metadata with the clawback reason.\n    entrypoint function issuerClawback(\n        pubkey issuerPk,\n        sig issuerSig,\n        pubkey issuerReceivePk\n    ) {\n        // Verify issuer identity via hash commitment\n        require(blake2b(issuerPk) == issuerKeyHash);\n        require(checkSig(issuerSig, issuerPk));\n\n        // First output: send reclaimed funds to issuer's receive address\n        byte[34] issuerLock = new ScriptPubKeyP2PK(issuerReceivePk);\n        require(tx.outputs[0].scriptPubKey == issuerLock);\n\n        // Transfer full value minus fee\n        int inputValue = tx.inputs[this.activeInputIndex].value;\n        require(tx.outputs[0].value >= inputValue - MINER_FEE);\n\n        // Second output: OP_RETURN with clawback reason metadata\n        // The reason is encoded in the transaction witness data\n        // Enforce that a second output exists (for the OP_RETURN data)\n        require(tx.outputs.length >= 2);\n    }\n}",
    "name_span": "Clawback"
  },
