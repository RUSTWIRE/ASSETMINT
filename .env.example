# AssetMint Environment Configuration
# Testnet-12 ONLY — NEVER connect to mainnet

# === Kaspa Testnet-12 ===
KASPA_RPC=ws://tn12-node.kaspa.com:17210
KASPA_NETWORK=testnet-12

# === Wallet (NEVER hardcode real keys) ===
# REPLACE_WITH_TESTNET_WALLET — generate dynamically
KASPA_PRIVATE_KEY=
KASPA_PUBLIC_KEY=

# === Self-Hosted DKG Edge Node ===
DKG_ENDPOINT=http://localhost:8900
DKG_PRIVATE_MODE=true

# === Compliance API ===
COMPLIANCE_API_PORT=3001
COMPLIANCE_DB_PATH=./data/compliance.sqlite

# === Oracle Pool (Simulated Centralized) ===
ORACLE_API_PORT=3002
# REPLACE_WITH_TESTNET_WALLET — oracle signer keys
ORACLE_SIGNER_KEY_1=
ORACLE_SIGNER_KEY_2=
ORACLE_SIGNER_KEY_3=

# === ASTM Token ===
ASTM_TICKER=ASTM
ASTM_MAX_SUPPLY=1000000000
ASTM_MINT_LIMIT=1000

# === Frontend ===
NEXT_PUBLIC_KASPA_RPC=ws://tn12-node.kaspa.com:17210
NEXT_PUBLIC_COMPLIANCE_API=http://localhost:3001
NEXT_PUBLIC_ORACLE_API=http://localhost:3002
NEXT_PUBLIC_DKG_ENDPOINT=http://localhost:8900
